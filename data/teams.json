name: Daten-Update vom DSV-Ergebnisdienst

on:
  schedule:
    - cron: '0 5-21/2 * * *'      # tagsüber alle 2 Stunden (UTC)
    - cron: '*/20 8-18 * * 0,6'   # Sa/So (Spieltage): alle 20 Minuten
  workflow_dispatch: {}            # Button "Run workflow" für manuellen Start

permissions:
  contents: write                  # darf data.json ins Repository schreiben

jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install httpx beautifulsoup4
      - run: python sync_worker/build_data.py
      - name: Änderungen committen
        run: |
          git config user.name "svk72-daten-bot"
          git config user.email "actions@users.noreply.github.com"
          git add data.json
          git diff --cached --quiet || { git commit -m "Daten-Update $(date -u +'%Y-%m-%d %H:%M') UTC"; git push; }
